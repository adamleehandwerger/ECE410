{
    "DESIGN_NAME": "svm_top_ihp",
    "VERILOG_FILES": [
        "dir::../rt1/top.sv",
        "dir::../rt1/compute_core_bb.v"
    ],
    "EXTRA_VERILOG_MODELS": [
        "dir::../rt1/compute_core_bb.v"
    ],
    "CLOCK_PORT": "clk",
    "CLOCK_NET": "clk",
    "CLOCK_PERIOD": 25,

    "FP_SIZING": "absolute",
    "DIE_AREA": "0 0 2400 2400",
    "PL_TARGET_DENSITY_PCT": 30,

    "SYNTH_STRATEGY": "AREA 0",
    "MAX_FANOUT_CONSTRAINT": 8,
    "MAX_TRANSITION_CONSTRAINT": 1.5,

    "MACRO_PLACEMENT_CFG": "dir::macro.cfg",

    "EXTRA_LEFS": [
        "dir::../pnr/gds/svm_compute_core.lef"
    ],
    "EXTRA_GDS": [
        "dir::../pnr/gds/svm_compute_core.gds"
    ],

    "PDN_MACRO_CONNECTIONS": ["u_svm VDD VSS VPWR VGND"],
    "ERROR_ON_DISCONNECTED_PINS": false,

    "RUN_CTS": 1,
    "RUN_FILL_INSERTION": 1,
    "RUN_ANTENNA_REPAIR": 1,
    "PDN_CORE_RING": 1,

    "VSRC_LOC_FILES": {
        "VDD": "dir::../pnr/vsrc_VDD.txt",
        "VSS": "dir::../pnr/vsrc_VSS.txt"
    },

    "RUN_LVS": 1,

    "RUN_KLAYOUT_DRC": 1,
    "RUN_KLAYOUT_XOR": 1,
    "RUN_MCSTA": 1,

    "PNR_SDC_FILE": "dir::svm_top_ihp.sdc",
    "SIGNOFF_SDC_FILE": "dir::svm_top_ihp.sdc",

    "pdk::ihp-sg13g2": {
        "STD_CELL_LIBRARY": "sg13g2_stdcell",
        "RT_MAX_LAYER": "Metal5",
        "CLOCK_PERIOD": 25
    }
}
